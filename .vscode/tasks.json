{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "dev",
      "detail": "Start backend + UI dev server with hot reload",
      "dependsOn": ["dev:backend:serve", "dev:backend:watch", "dev:ui"],
      "problemMatcher": [],
      "group": {
        "kind": "build",
        "isDefault": true
      }
    },
    {
      "label": "dev:backend:serve",
      "type": "shell",
      "command": "npm run build && node build/cli.js serve",
      "isBackground": true,
      "problemMatcher": {
        "pattern": {
          "regexp": "^$"
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".",
          "endsPattern": "^Deskcheck UI:"
        }
      },
      "presentation": {
        "group": "dev",
        "reveal": "always"
      }
    },
    {
      "label": "dev:backend:watch",
      "type": "shell",
      "command": "npm run dev",
      "isBackground": true,
      "problemMatcher": ["$tsc-watch"],
      "presentation": {
        "group": "dev",
        "reveal": "silent"
      }
    },
    {
      "label": "dev:ui",
      "type": "shell",
      "command": "npm run dev",
      "options": {
        "cwd": "${workspaceFolder}/ui"
      },
      "isBackground": true,
      "problemMatcher": [],
      "presentation": {
        "group": "dev",
        "reveal": "always"
      }
    }
  ]
}
